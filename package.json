{
  "name": "code-intel",
  "version": "0.1.0",
  "description": "Standalone code-intelligence CLI and MCP server for source routing, impact maps, outlines, and symbol reads.",
  "type": "module",
  "license": "MIT",
  "author": "BadLiveware",
  "keywords": [
    "mcp",
    "code-intelligence",
    "claude-code",
    "source-analysis"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BadLiveware/code-intel.git"
  },
  "bugs": {
    "url": "https://github.com/BadLiveware/code-intel/issues"
  },
  "homepage": "https://github.com/BadLiveware/code-intel#readme",
  "files": [
    "README.md",
    "LICENSE",
    "dist",
    "docs",
    "package.json"
  ],
  "main": "./dist/tool-registry.js",
  "types": "./dist/tool-registry.d.ts",
  "bin": {
    "code-intel": "./dist/standalone/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/tool-registry.d.ts",
      "import": "./dist/tool-registry.js"
    },
    "./standalone": {
      "types": "./dist/standalone/mcp.d.ts",
      "import": "./dist/standalone/mcp.js"
    },
    "./pi-integration": {
      "types": "./dist/pi-integration.d.ts",
      "import": "./dist/pi-integration.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && chmod +x dist/standalone/cli.js",
    "ci": "npm run typecheck && npm test && npm run build && npm run smoke:cli && npm run pack:dry-run",
    "clean": "rm -rf dist",
    "pack:dry-run": "npm pack --dry-run",
    "prepare": "npm run build",
    "smoke:cli": "node dist/standalone/cli.js list && node dist/standalone/cli.js call code_intel_file_outline --cwd src --json '{\"path\":\"tool-registry.ts\",\"maxSymbols\":3}' --format compact",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node --experimental-strip-types --test \"test/*.test.ts\""
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@vscode/tree-sitter-wasm": "^0.3.1",
    "typescript": "^5.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0"
  },
  "packageManager": "npm@10"
}
